# Vision AI Service Configuration
SERVICE_NAME=ai-vision
SERVICE_VERSION=1.0.0
PORT=8001
HOST=0.0.0.0
LOG_LEVEL=info

# Model Configuration
YOLO_MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.25
IOU_THRESHOLD=0.45
MAX_DETECTIONS=100

# Violation Configuration
DEDUPLICATION_WINDOW_SECONDS=10
VIOLATION_COOLDOWN_SECONDS=5

# Performance
MAX_IMAGE_SIZE=1280
BATCH_SIZE=1
DEVICE=cpu

# API Configuration
ALLOWED_ORIGINS=http://localhost:3003,http://localhost:3001
MAX_FILE_SIZE_MB=10

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30