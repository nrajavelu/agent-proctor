# Audio AI Service Configuration
SERVICE_NAME=ai-audio
SERVICE_VERSION=1.0.0
PORT=8002
HOST=0.0.0.0
LOG_LEVEL=info

# Whisper Configuration
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_LANGUAGE=en

# Audio Processing Configuration
SAMPLE_RATE=16000
CHUNK_DURATION_SECONDS=5
SILENCE_THRESHOLD=0.01
NOISE_THRESHOLD=0.5
SPEECH_THRESHOLD=0.3

# Speaker Detection
MAX_SPEAKERS=1
SPEAKER_DIARIZATION_ENABLED=true
SPEAKER_CONFIDENCE_THRESHOLD=0.5

# Violation Configuration
DEDUPLICATION_WINDOW_SECONDS=10
VIOLATION_COOLDOWN_SECONDS=5

# Performance
MAX_AUDIO_SIZE_MB=50
BATCH_SIZE=1
MAX_CONCURRENT_ANALYSIS=3

# API Configuration
ALLOWED_ORIGINS=http://localhost:3003,http://localhost:3001

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30