# Agent Runtime Configuration

# Basic Configuration
NODE_ENV=development
PORT=3003
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Database Configuration (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=agent_proctor_dev
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SSL=false
DATABASE_POOL_SIZE=10

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# LiveKit Configuration
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_secret

# AI Services Configuration
AI_VISION_SERVICE_URL=http://localhost:8001
AI_AUDIO_SERVICE_URL=http://localhost:8002
AI_BEHAVIOR_SERVICE_URL=http://localhost:8003
AI_SERVICE_TIMEOUT=30000

# API Gateway Integration
API_GATEWAY_URL=http://localhost:3001

# Agent Configuration
AGENT_FRAME_RATE=2
AGENT_AUDIO_CHUNK_SIZE=16000
AGENT_QUEUE_MAX_SIZE=100
AGENT_MAX_RESTARTS=3

# Performance Tuning
PROCESSING_QUEUE_SIZE=50
MAX_CONCURRENT_ANALYSIS=5
WEBHOOK_TIMEOUT=10000