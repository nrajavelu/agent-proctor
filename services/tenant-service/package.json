{
  "name": "@agent-proctor/tenant-service",
  "version": "1.0.0",
  "description": "Multi-tenant organization management and white-label branding service",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rimraf dist",
    "db:init": "chmod +x scripts/init-db.sh && scripts/init-db.sh",
    "env:setup": "cp .env.dev .env && echo '✅ Environment file created! Edit .env as needed.'",
    "dev:setup": "pnpm env:setup && pnpm db:init && echo '🚀 Development environment ready!'",
    "health": "curl -s http://localhost:3000/health || echo 'Service not running'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.450.0",
    "axios": "^1.14.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^2.30.0",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "helmet": "^7.2.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.17.21",
    "minio": "^7.1.4",
    "morgan": "^1.10.0",
    "multer": "1.4.5-lts.2",
    "node-cron": "^3.0.3",
    "pg": "^8.20.0",
    "redis": "^4.6.10",
    "sharp": "^0.32.6",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/lodash": "^4.14.200",
    "@types/morgan": "^1.9.7",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.9.1",
    "@typescript-eslint/parser": "^6.9.1",
    "eslint": "^8.52.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.1",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2"
  },
  "keywords": [
    "multi-tenant",
    "organization",
    "branding",
    "white-label",
    "enterprise",
    "proctoring"
  ],
  "author": "Agent Proctor Team",
  "license": "MIT"
}