# Service Configuration
NODE_ENV=development
PORT=3005
HOST=0.0.0.0
LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/agent_proctor
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
API_KEY_SECRET=your-api-key-secret-for-org-keys

# Storage Configuration
STORAGE_TYPE=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_USE_SSL=false

# AWS S3 (alternative to MinIO)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Keycloak Configuration
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_MASTER_REALM=master

# Multi-Tenant Configuration
MAX_ORGS_PER_SUPER_ADMIN=100
DEFAULT_ORG_STORAGE_LIMIT_GB=100
DEFAULT_ORG_SESSION_LIMIT=1000
ORG_TRIAL_PERIOD_DAYS=30

# Branding Configuration
MAX_LOGO_SIZE_MB=5
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/svg+xml
MAX_CSS_SIZE_KB=500
BRANDING_CDN_URL=https://cdn.ayan.nunmai.local

# API Configuration
CORS_ORIGINS=http://localhost:3001,http://localhost:3003,http://localhost:3006
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_ENABLED=true

# Webhooks
WEBHOOK_TIMEOUT_MS=30000
WEBHOOK_RETRY_COUNT=3
WEBHOOK_SECRET_KEY=webhook-signature-secret

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
PERFORMANCE_MONITORING=true

# External Services
EMAIL_PROVIDER=smtp
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@ayan.nunmai.local

# SDK Configuration
SDK_CDN_URL=https://sdk.ayan.nunmai.local
SDK_VERSION=1.0.0
AGENT_JS_VERSION=1.0.0