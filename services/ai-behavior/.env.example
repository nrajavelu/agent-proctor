# Service Configuration
SERVICE_NAME=ai-behavior
SERVICE_VERSION=1.0.0
PORT=8003
HOST=0.0.0.0
LOG_LEVEL=info

# MediaPipe Configuration
MEDIAPIPE_MAX_NUM_FACES=2
MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.5
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5
MEDIAPIPE_STATIC_IMAGE_MODE=false

# Pose Detection
POSE_MODEL_COMPLEXITY=1
POSE_MIN_DETECTION_CONFIDENCE=0.5
POSE_MIN_TRACKING_CONFIDENCE=0.5
FULL_BODY_ANALYSIS=true

# Hand Detection
HANDS_MAX_NUM_HANDS=2
HANDS_MIN_DETECTION_CONFIDENCE=0.7
HANDS_MIN_TRACKING_CONFIDENCE=0.5

# Face Analysis
FACE_MAX_NUM_FACES=1
FACE_MIN_DETECTION_CONFIDENCE=0.7
FACE_MESH_REFINE_LANDMARKS=true

# Behavior Analysis Thresholds
MOVEMENT_THRESHOLD=0.15
HEAD_MOVEMENT_THRESHOLD=20.0
EYE_TRACKING_THRESHOLD=0.3
SUSPICIOUS_GESTURE_THRESHOLD=0.6
ATTENTION_TRACKING_ENABLED=true

# Frame Processing
FRAME_SKIP_RATIO=2
MAX_FRAME_SIZE_MB=10
BATCH_PROCESSING=true
BATCH_SIZE=5

# Performance Configuration
MAX_CONCURRENT_ANALYSIS=4
PROCESSING_TIMEOUT_SECONDS=30
MEMORY_LIMIT_MB=2048

# Violation Detection
DEDUPLICATION_WINDOW_SECONDS=15
VIOLATION_COOLDOWN_SECONDS=10
CONFIDENCE_THRESHOLD=0.6

# API Configuration
ALLOWED_ORIGINS=http://localhost:3003,http://localhost:3001
MAX_REQUEST_SIZE_MB=25
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Monitoring
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
PERFORMANCE_LOGGING=true