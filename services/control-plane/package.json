{
  "name": "@agentic-proctor/control-plane",
  "version": "0.1.0",
  "description": "Central management service for agentic AI proctoring",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "docker:build": "docker build -t control-plane .",
    "docker:run": "docker run -p 3001:3001 control-plane"
  },
  "dependencies": {
    "@agentic-proctor/shared": "workspace:*",
    "@agentic-proctor/types": "workspace:*",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "kafka-node": "^5.0.0",
    "pg": "^8.11.3",
    "redis": "^4.6.12",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "jest": "^29.7.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}